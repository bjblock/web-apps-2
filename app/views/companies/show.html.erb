<h1><%= @company["name"] %></h1>
<h2><%= @company["city"] %>, <%= @company["state"] %></h2>

<h3>Contacts</h3>
<% for contact in @contacts %>
  <li>
    <a href="/contacts/<%= contact["id"] %>">
      <%= contact["first_name"] %>
      <%= contact["last_name"] %>
    </a>
  </li>
<% end %>

<p>
  <a href="/contacts/new?company_id=<%= @company["id"] %>">
    Add a Contact for <%= @company["name"] %>
  </a>
</p>

<p>
  <a href="/companies">Back to all companies</a>
</p>